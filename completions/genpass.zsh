#compdef genpass
_arguments \
  '--length[-l]:password length:' \
  '--count[-n]:number of passwords:' \
  '--lower[use lowercase letters]' \
  '--upper[use uppercase letters]' \
  '--digits[use digits]' \
  '--symbols[use symbols]' \
  '--symbol-set[custom symbol set]' \
  '--no-ensure[do not enforce each type]'
